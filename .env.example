# ============================================================
# CoinGlance — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# None of these are required for the app to work — all default
# to safe fallbacks. CoinGlance uses only free public APIs.
# ============================================================

# --- Google Analytics ---
# Get your Measurement ID from https://analytics.google.com
# Format: G-XXXXXXXXXX
# Leave blank to disable analytics entirely (no tracking will occur)
NEXT_PUBLIC_GA_ID=

# --- CoinGecko API Key (optional) ---
# The free public API works fine for most usage.
# For higher rate limits, add your API key from https://coingecko.com/en/api
# COINGECKO_API_KEY=

# --- Site URL ---
# Only needed if you deploy to a non-standard domain during development
# NEXT_PUBLIC_SITE_URL=https://coinglance.app
